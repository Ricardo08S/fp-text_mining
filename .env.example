# Copy this file to .env for local development.
# Do not commit .env.

# OpenRouter key for future LLM explanation/regeneration features.
OPENROUTER_API_KEY=

# Groq key for future LLM explanation/regeneration features.
GROQ_API_KEY=

# Optional: override artifact paths without moving files into app-final/artifacts.
XAI_DETAILED_CSV_PATH=
XAI_JUDGED_CSV_PATH=
